<script>
// State management
let state = {
  products: [],
  categories: [],
  sectors: [],
  certifications: [],
  cart: [],
  filters: {
    category: 'all',
    sector: 'all',
    cert: 'all',
    price: 25000,
    search: ''
  },
  loading: true,
  error: null
};
// API Configuration
// Since the HTML is now served from Django, use relative URLs
const API_BASE_URL = '';  // Empty means same origin
const API_ENDPOINTS = {
  cart: "/store/api/cart/",
  products: '/store/api/products/',
  categories: '/store/api/categories/',
  productDetail: (id) => `/store/api/products/${id}/`
};

// Load products function remains the same
async function loadProductsFromCMS() {
  try {
    console.log('Fetching from:', API_ENDPOINTS.products);
    
    const response = await fetch(API_ENDPOINTS.products);
    
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }
    
    const products = await response.json();
    console.log('Products from CMS:', products);
    
    state.products = products;
    
    // Extract categories
    const categories = [...new Set(products.map(p => p.category))];
    state.categories = categories.map(cat => ({
      id: cat,
      name: String(cat).charAt(0).toUpperCase() + String(cat).slice(1)
    }));
    
    renderCategories();
    filterAndRenderProducts();
    updateHeroStats();
    
  } catch (error) {
    console.error('Error loading from CMS:', error);
    showError('Failed to connect to CMS. Make sure Django server is running.');
  }
}
// DOM elements
const productGrid = document.getElementById('productGrid');
const cartCount = document.querySelector('.cart-count');
const priceValue = document.getElementById('priceValue');
const heroStats = document.getElementById('heroStats');

// Initialize
document.addEventListener('DOMContentLoaded', async () => {
  await loadInitialData();
  await loadCart();
  setupEventListeners();
  updatePriceDisplay();
});

// Setup event listeners
function setupEventListeners() {
  // Debounced search
  let searchTimeout;
  window.searchProducts = (query) => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      state.filters.search = query.toLowerCase();
      filterAndRenderProducts();
    }, 300);
  };
}

// Load initial data from backend
async function loadInitialData() {
  try {
    state.loading = true;
    showLoading();

    // Fetch only the endpoints that exist
    const [productsRes, categoriesRes] = await Promise.all([
      fetch(`${API_ENDPOINTS.products}`),
      fetch(`${API_ENDPOINTS.categories}`)
    ]);

    // Check responses
    if (!productsRes.ok) throw new Error("Failed to load products");
    if (!categoriesRes.ok) throw new Error("Failed to load categories");

    // Parse responses
    const products = await productsRes.json();
    const categories = await categoriesRes.json();

    // Update state
    state.products = products;
    state.categories = categories;
    state.sectors = []; // Initialize empty
    state.certifications = []; // Initialize empty

    // Update UI
    renderCategories();
    renderSectors();
    renderCertifications();

function closeModal() {
  document.getElementById('productModal').classList.remove('active');
}
// Cart functions
async function toggleCart() {
  try {
    const response = await fetch(API_ENDPOINTS.cart, {
      credentials: 'include'
    });
    
    if (!response.ok) throw new Error('Failed to load cart');
    
    const cartData = await response.json();
    const total = cartData.items.reduce((sum, item) => sum + (item.price * item.quantity), 0);
    
    alert(`Cart contains ${cartData.items.length} items\nTotal: KES ${total.toLocaleString()}`);
  } catch (error) {
    console.error('Error loading cart:', error);
    alert('Failed to load cart');
  }
}

async function addToCartFromModal() {
  const productId = document.getElementById('modalBody').dataset.currentProduct;
  const quantity = parseInt(document.getElementById('quantity').value) || 1;
  
  try {
    const product = state.products.find(p => p.id === productId);
    if (!product) return;
    
    const response = await fetch(`${API_ENDPOINTS.cart}/add`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      credentials: 'include',
      body: JSON.stringify({
        productId: productId,
        quantity: quantity
      })
    });
    
    if (!response.ok) throw new Error('Failed to add to cart');
    
    const cartData = await response.json();
    state.cart = cartData.items || [];
    updateCartCount();
    showNotification(`${quantity} × ${product.name} added to cart!`);
    closeModal();
    
  } catch (error) {
    console.error('Error adding to cart:', error);
    showNotification('Failed to add to cart', 'error');
  }
}
  document.getElementById('productModal').classList.remove('active');
}

// Notification system
function showNotification(message, type = 'success') {
  const notification = document.createElement('div');
  notification.style.cssText = `
    position: fixed;
    top: 20px;
    right: 20px;
    background: ${type === 'success' ? 'var(--accent)' : 'var(--danger)'};
    color: white;
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    z-index: 1000;
    animation: slideIn 0.3s ease-out;
  `;
  
  notification.innerHTML = `
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>
      <span>${message}</span>
    </div>
  `;
  
  document.body.appendChild(notification);
  
  setTimeout(() => {
    notification.style.animation = 'slideOut 0.3s ease-out';
    setTimeout(() => notification.remove(), 300);
  }, 3000);
}

// Add CSS for notifications (already in style section)
</script>

</body>
</html>

// Modal function
function closeModal() {
  document.getElementById('productModal').classList.remove('active');
}
